.env
.env.local
bin/
!plugins/*/bin/
!plugins/*/bin/**
dist/
coverage/
.superpowers/
node_modules/
web/node_modules/
web/.next/
web/tsconfig.tsbuildinfo
web/tsconfig.test.tsbuildinfo
docs/screenshots/
tmp/
.tmp/
*.log

# AI usage collector binary
/stint-collect
/collect

# Keep the collector state dir (committed so Docker doesn't auto-create it as
# root and break the uid-1000 collector), but ignore the actual scan state.
/.collector-state/*
!/.collector-state/.gitkeep
